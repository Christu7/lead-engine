DATABASE_URL=postgresql+asyncpg://leadengine:leadengine@db:5432/leadengine
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-in-production   # Must be ≥32 chars in production
ALLOWED_ORIGINS=                     # Prod: comma-separated exact origins, no wildcards (e.g. https://app.example.com)
BACKEND_URL=http://localhost:8000    # Prod: set to your production backend URL (no localhost)
FRONTEND_URL=http://localhost:3000   # Prod: set to your production frontend URL (no localhost)
VITE_API_BASE_URL=                  # Frontend API base. Leave empty in dev (proxied to /api). Prod: set to your backend origin (e.g. https://api.example.com/api)

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60       # Default: 60 minutes

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APOLLO_WEBHOOK_SECRET=your-apollo-webhook-secret
TYPEFORM_WEBHOOK_SECRET=        # Optional: set to verify X-Typeform-Signature header
WEBSITE_WEBHOOK_SECRET=         # Optional: set to verify X-Webhook-Signature header
APOLLO_API_KEY=                 # Required for company enrichment and contact pulls

# Seed script credentials
ADMIN_EMAIL=admin@leadengine.local
ADMIN_PASSWORD=changeme
DEFAULT_CLIENT_NAME=Default

# Observability
LOG_LEVEL=INFO                  # DEBUG for verbose dev output
SENTRY_DSN=                     # Leave empty to disable Sentry
DEBUG=false                     # Set to true in dev for tracebacks in error responses

# AI enrichment
ANTHROPIC_API_KEY=              # Required to enable AI lead analysis (or set via Settings > API Key Store)
OPENAI_API_KEY=                 # Optional: set to use OpenAI instead of Anthropic
AI_PROVIDER=anthropic           # "anthropic" or "openai" when both keys are set

# Encryption (required for API Key Store)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=                 # Must be a valid Fernet key

# Task queue / rate limiting
APOLLO_RATE_LIMIT_PER_MINUTE=10    # Max Apollo API calls per minute (worker enforces this via delays)
ANTHROPIC_RATE_LIMIT_PER_MINUTE=20 # Max Anthropic API calls per minute
APOLLO_REQUEST_DELAY_MS=500        # Milliseconds to wait between consecutive Apollo tasks

# Testing (Session 18)
TEST_DATABASE_URL=postgresql+asyncpg://leadengine:leadengine@db:5432/leadengine_test

# Used by docker-compose.prod.yml for the postgres container
POSTGRES_USER=leadengine
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=leadengine

# Redis authentication (docker-compose.prod.yml only — dev uses no password)
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=change-me-in-production
